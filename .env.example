# Hourly dashboard — production (VPS / Docker)
# Copy to .env before: ./deploy.sh
#
# Use EITHER naming style (deploy.sh maps SUPABASE_* → NEXT_PUBLIC_* automatically):

# --- Style A (Next.js / recommended) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-or-anon-key

# --- Style B (also works if you already use these for migrate/seed) ---
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

PORT=8001
HOSTNAME=0.0.0.0

# Optional: server-side only (migrate/seed on host, not needed in container)
# SUPABASE_SECRET_KEY=   # required on dashboard for client screenshot images
# DATABASE_URL=
