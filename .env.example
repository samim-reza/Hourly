# Hourly dashboard — production (VPS / Docker)
# Copy to .env and fill in values before: docker compose up -d --build

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-or-anon-key

# App listen port (must match Caddy upstream hourly-app:8001)
PORT=8001
HOSTNAME=0.0.0.0

# Optional: server-side only (not used by Next.js client; for migrate script on host)
# SUPABASE_SECRET_KEY=
# DATABASE_URL=
